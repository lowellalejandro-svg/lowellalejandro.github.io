// CARRITO
let carrito = [];

// CARGAR CARRITO DEL STORAGE
function cargarCarritoDelStorage() {
    const carritoGuardado = localStorage.getItem('carrito');
    if (carritoGuardado) {
        carrito = JSON.parse(carritoGuardado);
    }
}

// GUARDAR CARRITO EN STORAGE
function guardarCarrito() {
    localStorage.setItem('carrito', JSON.stringify(carrito));
}

// AGREGAR AUTO AL CARRITO
function agregarAlCarrito(idAuto) {
    const auto = autos.find(a => a.id === idAuto);
    if (!auto) return;

    const itemExistente = carrito.find(item => item.id === idAuto);
    
    if (itemExistente) {
        itemExistente.cantidad++;
    } else {
        carrito.push({
            id: auto.id,
            nombre: auto.nombre,
            precio: auto.precio,
            imagen: auto.imagen,
            detalles: auto.detalles,
            cantidad: 1
        });
    }
    
    guardarCarrito();
    actualizarBadgeCarrito();
    alert(auto.nombre + " agregado al carrito");
}

// ACTUALIZAR BADGE DEL CARRITO
function actualizarBadgeCarrito() {
    const totalItems = carrito.reduce((sum, item) => sum + item.cantidad, 0);
    const badges = document.querySelectorAll('[data-carrito-count]');
    badges.forEach(badge => {
        badge.textContent = totalItems > 0 ? totalItems : '0';
    });
}

// INICIALIZAR
document.addEventListener('DOMContentLoaded', function() {
    cargarCarritoDelStorage();
    actualizarBadgeCarrito();
});